      "title": "Main",
      "content": "\n// CSG code goes here\nvar f1 = await font(\"/fonts/ClassicRomanCaps.ttf\");\nvar ts= text({\nfont:f1,\ntext:\"wELCOME!\",\nfn:30,\nfontSize:9\n});\n\nvar v1= await importSvg(\"./try1.svg\");\n\nPrintLog(v1);\nalignPath({cx:0,cy:0},ts)\nrotatePath(90,ts)\nvar p1= new Path3d().path([\n\"s\", 1,1,\n\"m\", 0,0, 0,\n\"s\",1.1,1.1,\n\"l\", 0,0, 3\n]).fn(30)\nreturn extrude3d(v1, p1);\n"
    }
